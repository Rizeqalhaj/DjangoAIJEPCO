# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (empty = SQLite, set to postgres URL when Docker is available)
# DATABASE_URL=postgres://kahrabaai:kahrabaai_dev@localhost:5432/kahrabaai
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (kept for future use)
ANTHROPIC_API_KEY=

# Groq (free LLM API — get key at https://console.groq.com)
GROQ_API_KEY=

# WhatsApp (fill in later in Phase 4)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=kahrabaai-verify-token
WHATSAPP_APP_SECRET=

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
